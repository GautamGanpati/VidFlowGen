# Leave empty to run in demo mode (mock AI generation, no backend required).
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Get these from: turso db show <db-name>  &&  turso db tokens create <db-name>
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

UPLOAD_PROMPT_IMAGE_FUNCTION=upload-prompt-image

# Required for on-device Gemma image-to-text (free HF account)
HUGGING_FACE_TOKEN=

# RunwayML API key — https://dev.runwayml.com (used for video generation)
RUNWAY_API_KEY=
